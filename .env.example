# Job Search Orchestration System — Environment Variables
# Copy this file to .env and fill in your keys

# Required — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Eventbrite API token for live event discovery (Module 2)
# Get from https://www.eventbrite.com/platform/api
EVENTBRITE_API_TOKEN=

# Optional — Apify API key for LinkedIn job scraping (Module 3)
# Get from https://apify.com/
APIFY_API_KEY=
